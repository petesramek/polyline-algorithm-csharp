{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "api-reference"
    }
  ],
  "build": {
    "content": [
      {
        "files": "**/*.{md,yml}",
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "media/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": " Polyline Algorithm for .NET",
      "_appTitle": "Polyline Algorithm for .NET",
      "_appFooter": "",
      "_appFaviconPath": "media/polyline-algorithm.ico",
      "_appLogoPath": "media/polyline-algorithm-50x46.png",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_disableNavbar": false,
      "_disableBreadcrumb": false,
      "_disableToc": false,
      "_disableAffix": false,
      "_disableContribution": true,
      "pdf": true
    },
    "sitemap": {
      "baseUrl": "https://petesramek.github.io/polyline-algorithm-csharp",
      "priority": 0.1,
      "changefreq": "monthly"
    }
  }
}